pipeline {
    agent any

    parameters {
        string(name: 'CHANGESET_ID',     defaultValue: '', description: 'Changeset ID to roll back')
        string(name: 'CHANGESET_AUTHOR', defaultValue: '', description: 'Author of the changeset')
        string(name: 'CHANGESET_PATH',   defaultValue: '', description: 'Path to the changelog file')
    }

    environment {
        LB_USERNAME    = credentials('pg-username')
        LB_PASSWORD    = credentials('pg-password')
        LB_LICENSE_KEY = credentials('lb-pro-license')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/BRLiquibase/liquibase-jenkins.git',
                    credentialsId: 'github-creds'
            }
        }

        stage('Rollback Last Update') {
            steps {
                sh '''
                    /Users/benriley/Documents/GitHub/liquibase-secure-5.0.0/liquibase flow \
                      --flow-file=flowfile.rollback.yaml
                '''
            }
        }
    }

    post {
        success {
            echo 'Rollback complete.'
        }
    }
}